# ──────────────────────────────────────────────────────────────────────────────
# Voyai Frontend — Environment Variables
# Copy this file to .env.local and fill in the values
# ──────────────────────────────────────────────────────────────────────────────

# Base URL for the Voyai backend API
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Geoapify browser key for destination/departure autocomplete
NEXT_PUBLIC_GEOAPIFY_API_KEY=
