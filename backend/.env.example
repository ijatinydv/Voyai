# Voyai Backend - Environment Variables
# Copy this file to .env and fill in the values.

# Server
PORT=5000
NODE_ENV=development

# Database
# Example Atlas: mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/voyai?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/voyai

# Authentication
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_a_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=CHANGE_ME_use_a_different_long_random_string_64_chars

# Novita AI
NOVITA_API_KEY=your_key_here
NOVITA_BASE_URL=https://api.novita.ai/openai
LLM_MODEL=deepseek/deepseek-v4-flash

# CORS
# Frontend origin(s), comma-separated for multiple origins.
CORS_ORIGIN=http://localhost:3000
